{
  "name": "hiit-web-app",
  "version": "4.0.0",
  "private": true,
  "description": "HIIT Workout Web App",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "serve": "vite --host 0.0.0.0 --port 8080",
    "preview": "vite preview --host 0.0.0.0 --port 8080",
    "serve:preview": "npm run build && npm run preview",
    "preview:test": "vite preview --host 0.0.0.0 --port 4173",
    "preview:pwa-test": "vite preview --host 0.0.0.0 --port 4174",
    "serve:test": "npm run build && npm run preview:test",
    "serve:pwa-test": "npm run build && npm run preview:pwa-test",
    "lint": "eslint .",
    "format:check": "prettier --check \"docs/**/*.md\" \"scripts/**/*.mjs\" \"tests/**/*.{js,ts}\" \"src/**/*.{css,ts,tsx}\" \"*.{mjs,ts}\" \"index.html\" \"package.json\" \".github/**/*.yml\"",
    "typecheck": "tsc --noEmit",
    "build": "vite build && npm run verify:pwa-build",
    "build:pages": "VITE_BASE_PATH=/hiit-web-app/ npm run build",
    "verify:pwa-build": "node scripts/assert-pwa-build.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:pwa": "playwright test --config playwright.pwa.config.mjs",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build && npm run test:e2e && npm run test:pwa"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/toastify-js": "^1.12.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "toastify-js": "^1.12.0"
  }
}
