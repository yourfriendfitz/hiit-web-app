{
  "name": "hiit-web-app",
  "version": "0.1.0",
  "private": true,
  "description": "HIIT Workout Web App",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "serve": "vite --host 0.0.0.0 --port 8080",
    "preview": "vite preview --host 0.0.0.0 --port 8080",
    "preview:test": "vite preview --host 0.0.0.0 --port 4173",
    "serve:test": "npm run build && npm run preview:test",
    "lint": "eslint .",
    "format:check": "prettier --check \"docs/**/*.md\" \"tests/**/*.{js,ts}\" \"src/**/*.{ts,tsx}\" \"*.{mjs,ts}\" \"index.html\" \"package.json\" \".github/**/*.yml\"",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
